{
  "name": "@gertsai/fetch",
  "version": "0.3.0",
  "description": "HTTP client wrapper for gerts.ai using undici with Fetch API compatibility",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "undici": "^7.2.3"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "keywords": [
    "http",
    "fetch",
    "undici",
    "client",
    "gerts"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/gertsai/gertsai_codex.git",
    "directory": "packages/fetch"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
