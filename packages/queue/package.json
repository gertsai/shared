{
  "name": "@gertsai/queue",
  "version": "0.1.0",
  "description": "BullMQ wrapper primitives + standalone runner. Lazy peer-deps for opt-in. Per PRD-001 FR-019 + ADR-004.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./standalone": {
      "import": {
        "types": "./dist/standalone.d.ts",
        "default": "./dist/standalone.js"
      },
      "require": {
        "types": "./dist/standalone.d.cts",
        "default": "./dist/standalone.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "standalone": [
        "./dist/standalone.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "bullmq": "^5.0.0",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "bullmq": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "bullmq": "^5.0.0",
    "ioredis": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "queue",
    "bullmq",
    "redis",
    "worker",
    "moleculer-alternative",
    "gerts",
    "gertsai"
  ]
}
