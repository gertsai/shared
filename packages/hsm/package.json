{
  "name": "@gerts/hsm",
  "version": "0.0.1",
  "description": "Hardware Security Module (HSM) integration for convergent encryption",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./providers": {
      "import": {
        "types": "./dist/providers/index.d.ts",
        "default": "./dist/providers/index.js"
      },
      "require": {
        "types": "./dist/providers/index.d.ts",
        "default": "./dist/providers/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tspc --build tsconfig.json",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "bench": "vitest bench"
  },
  "dependencies": {},
  "devDependencies": {
    "@ryoppippi/unplugin-typia": "^2.6.5",
    "ts-patch": "^3.3.0",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@gerts/core": "workspace:*"
  }
}
