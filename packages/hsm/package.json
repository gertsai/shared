{
  "name": "@gertsai/hsm",
  "version": "3.0.0",
  "license": "Apache-2.0",
  "description": "Hardware Security Module (HSM) integration for convergent encryption",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./providers": {
      "import": {
        "types": "./dist/providers/index.d.ts",
        "default": "./dist/providers/index.js"
      },
      "require": {
        "types": "./dist/providers/index.d.cts",
        "default": "./dist/providers/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "providers": [
        "./dist/providers/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "bench": "vitest bench"
  },
  "dependencies": {},
  "devDependencies": {
    "@ryoppippi/unplugin-typia": "^2.6.5",
    "ts-patch": "^3.3.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@gertsai/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=22"
  }
}
