{
  "name": "@gerts/core",
  "version": "0.0.1",
  "description": "Core primitives for gerts.ai platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    },
    "./rag": {
      "import": { "types": "./dist/rag/index.d.ts", "default": "./dist/rag/index.js" },
      "require": { "types": "./dist/rag/index.d.ts", "default": "./dist/rag/index.js" }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "gpt-tokenizer": "^2.5.0",
    "llm-info": "^1.0.69",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
