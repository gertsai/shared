{
  "name": "@gertsai/entity-storage",
  "version": "3.0.0",
  "description": "Session-aware audit-stamped CRUD wrapper around IStorageProvider + InMemoryStorageProvider test fixture. Backend-agnostic. Per PRD-002 + ADR-005 + SPEC-008.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "@gertsai/di": "workspace:^",
    "@gertsai/entity": "workspace:^",
    "@gertsai/entity-audit": "workspace:^",
    "@gertsai/session": "workspace:^",
    "@gertsai/storage-core": "workspace:^"
  },
  "devDependencies": {
    "@gertsai/di": "workspace:*",
    "@gertsai/entity": "workspace:*",
    "@gertsai/entity-audit": "workspace:*",
    "@gertsai/session": "workspace:*",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "storage",
    "entity",
    "crud",
    "soft-delete",
    "audit",
    "in-memory",
    "ddd",
    "gerts",
    "gertsai"
  ],
  "author": "gerts.ai"
}
