{
  "name": "@gertsai/errors",
  "version": "0.2.0",
  "description": "Universal error taxonomy for @gertsai/* — 10 ErrorKind values + RFC 9457 ProblemDetails (/http) + gRPC status mapping (/grpc)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./http": {
      "import": {
        "types": "./dist/http/index.d.ts",
        "default": "./dist/http/index.js"
      },
      "require": {
        "types": "./dist/http/index.d.cts",
        "default": "./dist/http/index.cjs"
      }
    },
    "./grpc": {
      "import": {
        "types": "./dist/grpc/index.d.ts",
        "default": "./dist/grpc/index.js"
      },
      "require": {
        "types": "./dist/grpc/index.d.cts",
        "default": "./dist/grpc/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "http": [
        "./dist/http/index.d.ts"
      ],
      "grpc": [
        "./dist/grpc/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
