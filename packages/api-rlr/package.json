{
  "name": "@gerts/api-rlr",
  "version": "0.1.4",
  "description": "Gerts.ai API rate limit request middleware with Redis and Lua scripts",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "prepublish": "pnpm build",
    "copy:lua": "copyfiles -u 1 src/scripts/*.lua dist",
    "dev": "pnpm run build:watch",
    "build": "tsc && pnpm copy:lua",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:redis": "HAS_REDIS=1 vitest run",
    "test:coverage": "vitest run --coverage.enabled --coverage.reporter=html"
  },
  "author": "Eli Rum <explosivebit@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "consola": "^3.4.2",
    "lodash.clonedeep": "^4.5.0",
    "lodash.debounce": "^4.0.8",
    "lodash.get": "^4.4.2",
    "lodash.isequal": "^4.5.0",
    "lodash.merge": "^4.6.2",
    "lodash.mergewith": "^4.6.2",
    "lodash.set": "^4.3.2",
    "lodash.unset": "^4.5.2",
    "request-ip": "^3.3.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@gerts/api-core": "workspace:*",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.get": "^4.4.9",
    "@types/lodash.isequal": "^4.5.8",
    "@types/lodash.merge": "^4.6.9",
    "@types/lodash.mergewith": "^4.6.9",
    "@types/lodash.set": "^4.3.9",
    "@types/lodash.unset": "^4.5.9",
    "@types/request-ip": "^0.0.41",
    "@types/uuid": "^9.0.8",
    "copyfiles": "^2.4.1",
    "ioredis": "5.7.0",
    "moleculer": "^0.14.35",
    "moleculer-web": "^0.10.8",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
