{
  "name": "@gertsai/api-rlr",
  "version": "0.3.2",
  "description": "Production-grade rate limit middleware for Moleculer.js APIs — Redis (sliding-window + GCRA via Lua scripts), PostgreSQL (database-agnostic via PgClient interface), and in-memory adapters",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "prepublish": "pnpm build",
    "copy:lua": "copyfiles -u 1 src/scripts/*.lua dist",
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:redis": "HAS_REDIS=1 vitest run",
    "test:coverage": "vitest run --coverage.enabled --coverage.reporter=html",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "author": "Eli Rum <explosivebit@gmail.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@gertsai/api-core": "workspace:*",
    "@gertsai/utils": "workspace:*",
    "consola": "^3.4.2",
    "lodash.clonedeep": "^4.5.0",
    "lodash.debounce": "^4.0.8",
    "lodash.get": "^4.4.2",
    "lodash.isequal": "^4.5.0",
    "lodash.merge": "^4.6.2",
    "lodash.mergewith": "^4.6.2",
    "lodash.set": "^4.3.2",
    "lodash.unset": "^4.5.2",
    "request-ip": "^3.3.0",
    "uuid": "^9.0.1"
  },
  "peerDependencies": {
    "ioredis": "^5.7.0",
    "moleculer": "^0.14.0",
    "moleculer-web": "^0.10.8"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "moleculer": {
      "optional": true
    },
    "moleculer-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.get": "^4.4.9",
    "@types/lodash.isequal": "^4.5.8",
    "@types/lodash.merge": "^4.6.9",
    "@types/lodash.mergewith": "^4.6.9",
    "@types/lodash.set": "^4.3.9",
    "@types/lodash.unset": "^4.5.9",
    "@types/request-ip": "^0.0.41",
    "@types/uuid": "^9.0.8",
    "copyfiles": "^2.4.1",
    "ioredis": "5.7.0",
    "moleculer": "^0.14.35",
    "moleculer-web": "^0.10.8",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
