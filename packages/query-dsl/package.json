{
  "name": "@gertsai/query-dsl",
  "version": "2.0.0",
  "description": "Type-safe query DSL — constraint factories (whereField/orderBy/limit/startAt/startAfter/endAt/endBefore) compile-validated against Meta['indexed'] + reference Postgres compileToSql at /sql subpath. Per PRD-002 + ADR-005.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./sql": {
      "import": {
        "types": "./dist/sql.d.ts",
        "default": "./dist/sql.js"
      },
      "require": {
        "types": "./dist/sql.d.cts",
        "default": "./dist/sql.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "sql": [
        "./dist/sql.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "@gertsai/storage-core": "workspace:^"
  },
  "devDependencies": {
    "@gertsai/storage-core": "workspace:*",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "query",
    "dsl",
    "type-safe",
    "sql",
    "postgres",
    "storage",
    "gerts",
    "gertsai"
  ],
  "author": "gerts.ai"
}
