{
  "name": "@gertsai/logger-factory",
  "version": "2.0.0",
  "description": "Pluggable logger factory for @gertsai/* — root export with consoleBackend + /pino + /winston peer-optional subpaths. Per ADR-009 Decision B + I-17.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pino": {
      "import": {
        "types": "./dist/pino/index.d.ts",
        "default": "./dist/pino/index.js"
      },
      "require": {
        "types": "./dist/pino/index.d.cts",
        "default": "./dist/pino/index.cjs"
      }
    },
    "./winston": {
      "import": {
        "types": "./dist/winston/index.d.ts",
        "default": "./dist/winston/index.js"
      },
      "require": {
        "types": "./dist/winston/index.d.cts",
        "default": "./dist/winston/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "pino": [
        "./dist/pino/index.d.ts"
      ],
      "winston": [
        "./dist/winston/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "@gertsai/errors": "workspace:^",
    "pino": ">=8.0.0",
    "winston": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "pino": {
      "optional": true
    },
    "winston": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gertsai/errors": "workspace:*",
    "pino": "^9.0.0",
    "winston": "^3.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "logger",
    "factory",
    "pino",
    "winston",
    "redaction",
    "structured-logging",
    "gerts",
    "gertsai"
  ],
  "engines": {
    "node": ">=22"
  },
  "author": "gerts.ai"
}
