{
  "name": "@gertsai/m9s-cache",
  "version": "0.1.0",
  "description": "Moleculer-compatible cache abstraction with Redis/Valkey driver support",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "ioredis": "^5.8.0",
    "moleculer": "^0.14.0",
    "redlock": "5.0.0-beta.2"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "moleculer": {
      "optional": true
    },
    "redlock": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ioredis": "^5.8.0",
    "moleculer": "^0.14.35",
    "redlock": "5.0.0-beta.2",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "keywords": [
    "gerts",
    "cache",
    "moleculer",
    "redis",
    "valkey",
    "cluster"
  ],
  "author": "Gerts.ai",
  "license": "MIT"
}
