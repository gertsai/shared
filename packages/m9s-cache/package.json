{
  "name": "@gertsai/m9s-cache",
  "version": "0.2.0",
  "description": "Moleculer-compatible cache abstraction with Redis/Valkey driver support",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "ioredis": "^5.8.0",
    "moleculer": "^0.14.0",
    "redlock": "5.0.0-beta.2"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "moleculer": {
      "optional": true
    },
    "redlock": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ioredis": "^5.8.0",
    "moleculer": "^0.14.35",
    "redlock": "5.0.0-beta.2",
    "vitest": "^3.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "keywords": [
    "gerts",
    "cache",
    "moleculer",
    "redis",
    "valkey",
    "cluster"
  ],
  "author": "Gerts.ai",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
