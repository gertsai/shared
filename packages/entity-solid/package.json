{
  "name": "@gertsai/entity-solid",
  "version": "2.0.0",
  "description": "Solid reactivity adapter for @gertsai/entity — createStore-backed ReactiveAdapter + useEntity store accessor. Per ADR-008 Decision D.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "@gertsai/entity": "workspace:^",
    "solid-js": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gertsai/entity": "workspace:*",
    "solid-js": "^1.8.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "entity",
    "solid",
    "solid-js",
    "reactive",
    "adapter",
    "gerts",
    "gertsai"
  ],
  "author": "gerts.ai"
}
