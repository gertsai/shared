{
  "name": "@gertsai/session-guard",
  "version": "2.0.0",
  "description": "External invariant guards / predicates / assertions / dedicated errors for @gertsai/session — assertion-vs-check semantics over @gertsai/errors taxonomy. Per ADR-007 (Wave 5 Phase 2) Decision B + invariants I-5..I-7, I-13, I-18, I-19.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@gertsai/errors": "workspace:^",
    "@gertsai/session": "workspace:^"
  },
  "devDependencies": {
    "@gertsai/errors": "workspace:^",
    "@gertsai/session": "workspace:^",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "session",
    "guard",
    "assertion",
    "predicate",
    "authorization",
    "tenant",
    "impersonation",
    "gerts",
    "gertsai"
  ],
  "author": "gerts.ai"
}
