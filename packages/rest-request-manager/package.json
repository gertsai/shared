{
  "name": "@gertsai/rest-request-manager",
  "version": "4.0.0",
  "description": "Tier 2 HTTP request manager — retry + token-bucket rate limit + LRU circuit breaker per host + AppError translation. Per ADR-009 Decision D + invariants I-8/I-9/I-13/I-14.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@gertsai/async-utils": "workspace:^",
    "@gertsai/errors": "workspace:^",
    "@gertsai/fetch": "workspace:^",
    "@gertsai/logger-factory": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@gertsai/logger-factory": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gertsai/async-utils": "workspace:*",
    "@gertsai/errors": "workspace:*",
    "@gertsai/fetch": "workspace:*",
    "@gertsai/logger-factory": "workspace:*",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "rest",
    "http",
    "retry",
    "rate-limit",
    "circuit-breaker",
    "request-manager",
    "gerts",
    "gertsai"
  ],
  "author": "gerts.ai"
}
