{
  "name": "@gerts/collection",
  "version": "0.1.0",
  "description": "Modern TypeScript collection library with mutable, immutable, and persistent data structures",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./core/*": {
      "import": {
        "types": "./dist/core/*.d.ts",
        "default": "./dist/core/*.js"
      },
      "require": {
        "types": "./dist/core/*.d.ts",
        "default": "./dist/core/*.js"
      }
    },
    "./mixins/*": {
      "import": {
        "types": "./dist/mixins/*.d.ts",
        "default": "./dist/mixins/*.js"
      },
      "require": {
        "types": "./dist/mixins/*.d.ts",
        "default": "./dist/mixins/*.js"
      }
    },
    "./operations/*": {
      "import": {
        "types": "./dist/operations/*.d.ts",
        "default": "./dist/operations/*.js"
      },
      "require": {
        "types": "./dist/operations/*.d.ts",
        "default": "./dist/operations/*.js"
      }
    },
    "./specialized/*": {
      "import": {
        "types": "./dist/specialized/*.d.ts",
        "default": "./dist/specialized/*.js"
      },
      "require": {
        "types": "./dist/specialized/*.d.ts",
        "default": "./dist/specialized/*.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "collection",
    "map",
    "set",
    "immutable",
    "persistent",
    "data-structures",
    "typescript"
  ],
  "author": "gerts.ai",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
