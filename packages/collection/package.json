{
  "name": "@gertsai/collection",
  "version": "0.3.1",
  "description": "Modern TypeScript collection library with mutable, immutable, and persistent data structures",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core/*": {
      "import": {
        "types": "./dist/core/*.d.ts",
        "default": "./dist/core/*.js"
      },
      "require": {
        "types": "./dist/core/*.d.cts",
        "default": "./dist/core/*.cjs"
      }
    },
    "./mixins/*": {
      "import": {
        "types": "./dist/mixins/*.d.ts",
        "default": "./dist/mixins/*.js"
      },
      "require": {
        "types": "./dist/mixins/*.d.cts",
        "default": "./dist/mixins/*.cjs"
      }
    },
    "./operations/*": {
      "import": {
        "types": "./dist/operations/*.d.ts",
        "default": "./dist/operations/*.js"
      },
      "require": {
        "types": "./dist/operations/*.d.cts",
        "default": "./dist/operations/*.cjs"
      }
    },
    "./specialized/*": {
      "import": {
        "types": "./dist/specialized/*.d.ts",
        "default": "./dist/specialized/*.js"
      },
      "require": {
        "types": "./dist/specialized/*.d.cts",
        "default": "./dist/specialized/*.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "core/*": [
        "./dist/core/*.d.ts"
      ],
      "mixins/*": [
        "./dist/mixins/*.d.ts"
      ],
      "operations/*": [
        "./dist/operations/*.d.ts"
      ],
      "specialized/*": [
        "./dist/specialized/*.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "keywords": [
    "collection",
    "map",
    "set",
    "immutable",
    "persistent",
    "data-structures",
    "typescript"
  ],
  "author": "gerts.ai",
  "license": "Apache-2.0",
  "dependencies": {
    "@gertsai/utils": "workspace:*"
  },
  "devDependencies": {
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
