{
  "name": "@gertsai/entity-vue",
  "version": "0.1.0",
  "description": "Vue 3 ReactiveAdapter for @gertsai/entity — lazy-loads @vue/runtime-core (peer-optional). Per ADR-008 Decision B + Amendment 1.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "@gertsai/entity": "workspace:^",
    "@vue/runtime-core": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@vue/runtime-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gertsai/entity": "workspace:*",
    "@vue/runtime-core": "^3.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "entity",
    "vue",
    "reactive",
    "adapter",
    "shallowReactive",
    "gerts",
    "gertsai"
  ],
  "author": "gerts.ai"
}
