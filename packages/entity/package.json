{
  "name": "@gertsai/entity",
  "version": "0.0.0",
  "description": "Backend-agnostic entity base classes (Model, Entity, EntityWithMetadata) with pluggable reactivity. Mirrors Orchestra entity patterns. Per PRD-002 + ADR-005.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue.d.ts",
        "default": "./dist/vue.js"
      },
      "require": {
        "types": "./dist/vue.d.cts",
        "default": "./dist/vue.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "vue": ["./dist/vue.d.ts"]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/emit-vue-shim-dts.mjs",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@gertsai/session": "workspace:*"
  },
  "peerDependencies": {
    "@gertsai/entity-vue": "workspace:^",
    "@vue/runtime-core": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@gertsai/entity-vue": {
      "optional": true
    },
    "@vue/runtime-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vue/runtime-core": "^3.0.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "entity",
    "model",
    "reactive",
    "domain",
    "ddd",
    "gerts",
    "gertsai"
  ],
  "author": "gerts.ai"
}
