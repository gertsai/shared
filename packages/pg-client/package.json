{
  "name": "@gertsai/pg-client",
  "version": "2.0.0",
  "description": "Agnostic PostgreSQL client interface (3 methods) + mock fixture + optional ./storage adapter (PgStorageProvider implements @gertsai/storage-core IStorageProvider). Per ADR-004 + ADR-005 + ADR-011: NO Prisma/Drizzle/pg deps in core; adapter additive.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./storage": {
      "import": {
        "types": "./dist/storage.d.ts",
        "default": "./dist/storage.js"
      },
      "require": {
        "types": "./dist/storage.d.cts",
        "default": "./dist/storage.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "storage": [
        "./dist/storage.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "peerDependencies": {
    "@gertsai/storage-core": "workspace:^",
    "@gertsai/query-dsl": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@gertsai/storage-core": {
      "optional": true
    },
    "@gertsai/query-dsl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gertsai/entity-storage": "workspace:*",
    "@gertsai/query-dsl": "workspace:*",
    "@gertsai/storage-core": "workspace:*",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "agnostic",
    "interface",
    "storage",
    "adapter",
    "gerts",
    "gertsai"
  ],
  "author": "gerts.ai"
}
