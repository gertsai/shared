{
  "name": "@gertsai/pg-client",
  "version": "0.0.0",
  "description": "Agnostic PostgreSQL client interface (3 methods) + mock fixture. Per ADR-004 + ADR-011: NO Prisma/Drizzle/pg deps.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "agnostic",
    "interface",
    "gerts",
    "gertsai"
  ],
  "author": "gerts.ai"
}
