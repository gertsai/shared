{
  "name": "@gertsai/auth-openfga",
  "version": "0.3.1",
  "description": "OpenFGA integration for gerts.ai authorization (Zanzibar-style ReBAC)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./queries": {
      "import": {
        "types": "./dist/queries/index.d.ts",
        "default": "./dist/queries/index.js"
      },
      "require": {
        "types": "./dist/queries/index.d.cts",
        "default": "./dist/queries/index.cjs"
      }
    },
    "./mutations": {
      "import": {
        "types": "./dist/mutations/index.d.ts",
        "default": "./dist/mutations/index.js"
      },
      "require": {
        "types": "./dist/mutations/index.d.cts",
        "default": "./dist/mutations/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "queries": [
        "./dist/queries/index.d.ts"
      ],
      "mutations": [
        "./dist/mutations/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@gertsai/core": "workspace:*",
    "@openfga/sdk": "^0.8.1"
  },
  "devDependencies": {
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "auth",
    "authorization",
    "openfga",
    "zanzibar",
    "rbac",
    "rebac",
    "gerts"
  ],
  "author": "gerts.ai",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=22"
  }
}
