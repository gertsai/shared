{
  "name": "@gertsai/utils",
  "version": "0.5.0",
  "description": "Orchestra Utilities library",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./lru": {
      "import": {
        "types": "./dist/lru/index.d.ts",
        "default": "./dist/lru/index.js"
      },
      "require": {
        "types": "./dist/lru/index.d.cts",
        "default": "./dist/lru/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "lru": [
        "./dist/lru/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "consola": "^3.2.3",
    "lodash.get": "^4.4.2"
  },
  "devDependencies": {
    "@types/lodash.get": "^4.4.9",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
