{
  "name": "@gertsai/api-pubsub",
  "version": "0.1.0",
  "description": "Tier-2 Google Cloud Pub/Sub topic-subscription lifecycle for @gertsai/api-core — registry + Moleculer service-schema fragment + boot/teardown. Per PRD-052 / EVID-067 §15.C.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "lodash.forin": "^4.4.0"
  },
  "peerDependencies": {
    "@google-cloud/pubsub": "^4.0.0",
    "bullmq": "^5.0.0",
    "moleculer": "^0.14.0"
  },
  "peerDependenciesMeta": {
    "@google-cloud/pubsub": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    },
    "moleculer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@google-cloud/pubsub": "^4.11.0",
    "@types/lodash.forin": "^4.4.9",
    "bullmq": "^5.34.8",
    "moleculer": "^0.14.35",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "pubsub",
    "google-cloud-pubsub",
    "moleculer",
    "gerts",
    "gertsai"
  ]
}
