# SPDX-License-Identifier: Apache-2.0
# m9s-example environment variables — placeholder credentials only
# Copy to .env and fill in with actual values (NOT committed to git)

# === Storage ===
STORAGE_PROVIDER=postgres              # postgres | memory
POSTGRES_URL=postgres://m9s:change-me-on-deploy@localhost:5432/m9s
POSTGRES_PASSWORD=change-me-on-deploy
MIGRATIONS_AUTO_APPLY=false           # dev only — keep false in CI/prod, run `pnpm migrate:up` explicitly

# === Authorization (OpenFGA) ===
AUTH_GATE=openfga                      # openfga | allow-all
FGA_API_URL=http://localhost:8080
FGA_STORE_ID=                          # populated by openfga-bootstrap.ts
FGA_API_TOKEN=                         # preshared bearer (REQUIRED for production)

# === Async + cache ===
REDIS_URL=redis://localhost:6379

# === Embedder (Ollama) ===
EMBEDDER_PROVIDER=ollama
EMBEDDER_URL=http://localhost:11434
EMBEDDER_MODEL=nomic-embed-text

# Wave 8.1+ — RestRequestManager hardening knobs for both embedders.
# Defaults: Ollama 10 rps / burst 20 (local, unmetered); OpenAI 1 rps /
# burst 5 (conservative for paid metered API). NOTE these env vars are
# SHARED across both embedders — if both run in one process, you cannot
# tune them independently. For OpenAI workloads with >1 rps budgets,
# raise these explicitly.
EMBEDDER_RATE_LIMIT_RPS=               # default 10 (Ollama) or 1 (OpenAI)
EMBEDDER_BURST=                        # default 20 (Ollama) or 5 (OpenAI)

# === Logging ===
# Honored by @gertsai/logger-factory via src/composition/logger.ts.
# Unknown values fall back to 'info' silently.
LOG_LEVEL=info                          # trace | debug | info | warn | error | fatal

# === Real-infra test gates ===
PGVECTOR_E2E=
OPENFGA_E2E=
BULLMQ_E2E=
OLLAMA_E2E=

# === Optional ===
NODE_ENV=development                   # AllowAll refuses production (I-12)
TRANSPORT_TYPE=null
