{
  "extends": "../../tsconfig.base.json",
  "ts-node": {
    "compiler": "ts-patch/compiler",
    "transpileOnly": false,
    "experimentalSpecifierResolution": "node"
  },
  "compilerOptions": {
    "noEmit": false,
    // declaration/declarationMap intentionally off — m9s-example is a runnable
    // app, not a published library, so no consumer ever imports its `.d.ts`.
    // Keeping them on caused TS2742 after Wave 13 tightened `defineAction` to
    // preserve inferred shape: `typia.createValidate<T>()` returns an
    // intersection with `StandardSchemaV1<unknown, T>`, and TS could not name
    // the leaked path portably (`packages/api-core/node_modules/@standard-schema/spec`).
    "declaration": false,
    "declarationMap": false,
    "baseUrl": ".",
    "outDir": "./dist",
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "transform": "typescript-transform-paths"
      },
      {
        "transform": "typia/lib/transform"
      }
    ]
  },
  "include": ["src", "moleculer.config.ts", "project.config.ts"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "tests", "dist"]
}
