{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "outDir": "./dist",
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "transform": "typescript-transform-paths"
      },
      {
        "transform": "typescript-transform-paths",
        "afterDeclarations": true
      },
      {
        "transform": "typia/lib/transform"
      }
    ]
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "tests", "dist"]
}
