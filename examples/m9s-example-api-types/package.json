{
  "name": "@gertsai-examples/m9s-example-api-types",
  "version": "0.0.4",
  "private": true,
  "description": "OpenAPI 3.1 types generated from the m9s-example backend (Wave 9 reference application)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./openapi": {
      "import": {
        "types": "./dist/openapi/index.d.ts",
        "default": "./dist/openapi/index.js"
      }
    },
    "./generated": {
      "types": "./dist/generated/openapi-schema.d.ts"
    }
  },
  "files": [
    "dist",
    "src/generated/openapi.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/generated && cp src/generated/openapi-schema.d.ts dist/generated/openapi-schema.d.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "generate:openapi": "node scripts/generate-openapi-contract.mjs",
    "test": "echo 'no tests yet (Wave 9 — generator validated via Teammate B build + m9s-example-web typecheck consumption)'"
  },
  "dependencies": {
    "@gertsai/api-core": "workspace:*",
    "@samchon/openapi": "^4.7.1",
    "typia": "^9.7.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.9.0",
    "@types/node": "^22.10.0"
  }
}
