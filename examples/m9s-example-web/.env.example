# SvelteKit env (consumed via $env/dynamic/public or process.env at build).
# Public values are exposed to the browser bundle — keep secret-free.

# m9s-example backend base URL (from src/lib/api/client.ts).
PUBLIC_API_BASE_URL=http://localhost:3031

# Demo tenant header sent on every request (Wave 9 fixed; Wave 10 adds switcher).
PUBLIC_TENANT_ID=tenant-acme

# Wave 10.A — HS256 secret used by `src/lib/server/jwt.ts` to verify the
# `auth_token` cookie. MUST match the backend `JWT_SECRET`. Placeholder
# default is DEMO-ONLY — replace with ≥256-bit random in any deployment.
JWT_SECRET=demo-secret-do-not-use-in-prod
